{{define "techtable"}}
  <h3 class="sub">{{.Title}}</h3>
  {{if .Items}}
  <table>
    <thead><tr><th>Name</th><th>Version</th><th>Confidence</th><th>Evidence</th></tr></thead>
    <tbody>
      {{range .Items}}<tr>
        <td><strong>{{.Name}}</strong></td>
        <td>{{if .Version}}{{.Version}}{{else}}&mdash;{{end}}</td>
        <td><span class="conf conf-{{.Confidence}}">{{.Confidence}}</span></td>
        <td class="muted">{{.Evidence}}</td>
      </tr>{{end}}
    </tbody>
  </table>
  {{else}}
  <p class="empty">None detected.</p>
  {{end}}
{{end}}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{.ProjectName}} — Production Health Report</title>
  <style>
    :root{
      --bg:#0d1117; --surface:#161b22; --surface2:#1c2430; --border:#2a3340;
      --text:#e6edf3; --muted:#9aa7b4; --accent:#2bb6c9; --accent-ink:#04222a; --track:#243040;
      --crit:#e5484d; --high:#f76808; --med:#d99700; --low:#7c8893; --ok:#2ea043;
      --shadow:0 1px 3px rgba(0,0,0,.4), 0 10px 30px rgba(0,0,0,.22);
      --font:ui-sans-serif,system-ui,-apple-system,"Segoe UI",Roboto,"Helvetica Neue",Arial,sans-serif;
      --mono:ui-monospace,"Cascadia Code","SF Mono","JetBrains Mono",Consolas,monospace;
    }
    [data-theme="light"]{
      --bg:#f6f8fa; --surface:#ffffff; --surface2:#eef1f5; --border:#dce2e9;
      --text:#1b2430; --muted:#5b6675; --accent:#0e8a9b; --accent-ink:#ffffff; --track:#e3e8ee;
      --shadow:0 1px 2px rgba(16,24,40,.06), 0 10px 28px rgba(16,24,40,.08);
    }
    *{box-sizing:border-box;}
    html{scroll-behavior:smooth;}
    body{margin:0;font-family:var(--font);background:var(--bg);color:var(--text);line-height:1.55;font-size:15px;-webkit-font-smoothing:antialiased;}
    .layout{display:grid;grid-template-columns:236px 1fr;max-width:1240px;margin:0 auto;}
    nav.toc{position:sticky;top:0;align-self:start;height:100vh;overflow:auto;padding:22px 14px;border-right:1px solid var(--border);font-size:.88rem;}
    nav.toc h4{color:var(--muted);text-transform:uppercase;letter-spacing:.08em;font-size:.68rem;margin:0 0 10px;}
    nav.toc a{display:flex;justify-content:space-between;gap:8px;color:var(--text);text-decoration:none;padding:7px 10px;border-radius:8px;}
    nav.toc a:hover{background:var(--surface2);color:var(--accent);}
    nav.toc .count{color:var(--muted);font-variant-numeric:tabular-nums;}
    main{padding:24px 30px 80px;min-width:0;}
    .appbar{display:flex;align-items:center;justify-content:space-between;padding-bottom:18px;}
    .brand{display:flex;align-items:center;gap:10px;color:var(--text);}
    .brand .logo{color:var(--accent);flex-shrink:0;}
    .brandname{font-weight:800;font-size:1.16rem;letter-spacing:-.02em;}
    .appbar-actions{display:flex;gap:8px;}
    .themebtn,.printbtn{background:var(--surface);color:var(--text);border:1px solid var(--border);border-radius:9px;padding:7px 12px;cursor:pointer;font-size:.85rem;font-family:inherit;}
    .themebtn:hover,.printbtn:hover{border-color:var(--accent);color:var(--accent);}
    header{padding-bottom:18px;margin-bottom:20px;border-bottom:1px solid var(--border);}
    h1{margin:0 0 5px;font-size:1.7rem;font-weight:700;letter-spacing:-.02em;text-wrap:balance;}
    h2{font-size:1.18rem;margin:38px 0 14px;font-weight:650;letter-spacing:-.01em;scroll-margin-top:14px;}
    h2::before{content:"";display:inline-block;width:4px;height:.92em;background:var(--accent);border-radius:2px;margin-right:11px;vertical-align:-1px;}
    h3.sub{margin:22px 0 8px;font-size:.95rem;font-weight:600;color:var(--text);}
    .muted{color:var(--muted);font-size:.9rem;}
    .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;}
    .card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:15px 17px;}
    .card .label{color:var(--muted);font-size:.7rem;text-transform:uppercase;letter-spacing:.05em;}
    .card .value{font-size:1.5rem;font-weight:700;margin-top:3px;font-variant-numeric:tabular-nums;}
    table{width:100%;border-collapse:collapse;margin-top:10px;font-size:.92rem;}
    th,td{text-align:left;padding:10px 12px;border-bottom:1px solid var(--border);vertical-align:top;}
    th{color:var(--muted);font-weight:600;font-size:.7rem;text-transform:uppercase;letter-spacing:.05em;}
    tbody tr:hover{background:var(--surface2);}
    .badge{display:inline-block;border-radius:999px;padding:3px 12px;margin:0 6px 6px 0;font-size:.82rem;background:color-mix(in srgb,var(--accent) 16%,transparent);color:var(--accent);}
    .empty{color:var(--muted);font-style:italic;}
    code{background:var(--surface2);padding:2px 6px;border-radius:6px;font-family:var(--mono);font-size:.82rem;word-break:break-all;}
    a{color:var(--accent);}
    .conf{font-size:.74rem;padding:2px 9px;border-radius:999px;font-weight:600;}
    .conf-High{background:color-mix(in srgb,var(--ok) 18%,transparent);color:var(--ok);}
    .conf-Medium{background:color-mix(in srgb,var(--med) 22%,transparent);color:var(--med);}
    .conf-Low{background:var(--surface2);color:var(--muted);}
    .sevbadge{font-size:.72rem;padding:3px 9px;border-radius:999px;font-weight:700;white-space:nowrap;display:inline-block;}
    .sevbadge.sev-Critical{background:color-mix(in srgb,var(--crit) 20%,transparent);color:var(--crit);}
    .sevbadge.sev-High{background:color-mix(in srgb,var(--high) 20%,transparent);color:var(--high);}
    .sevbadge.sev-Medium{background:color-mix(in srgb,var(--med) 24%,transparent);color:var(--med);}
    .sevbadge.sev-Low{background:var(--surface2);color:var(--muted);}
    .sev-Critical{color:var(--crit);} .sev-High{color:var(--high);} .sev-Medium{color:var(--med);} .sev-Low{color:var(--low);}
    .controls{display:flex;flex-wrap:wrap;gap:8px;align-items:center;margin:14px 0;}
    .controls button{background:var(--surface);color:var(--text);border:1px solid var(--border);border-radius:999px;padding:6px 14px;cursor:pointer;font-size:.84rem;font-family:inherit;}
    .controls button:hover{border-color:var(--accent);}
    .controls button.active{background:var(--accent);color:var(--accent-ink);border-color:var(--accent);font-weight:700;}
    .controls select,.controls input{background:var(--surface);color:var(--text);border:1px solid var(--border);border-radius:9px;padding:7px 11px;font-size:.84rem;font-family:inherit;}
    .controls input{flex:1;min-width:170px;}
    .pill{display:inline-block;background:var(--surface);border:1px solid var(--border);border-radius:9px;padding:7px 13px;cursor:pointer;color:var(--text);text-decoration:none;font-size:.88rem;}
    .pill:hover{border-color:var(--accent);color:var(--accent);}
    .fix{margin-top:5px;}
    .fixwrap{margin-top:6px;}
    .fixwrap summary{cursor:pointer;color:var(--accent);font-size:.8rem;font-weight:600;list-style:none;}
    .fixwrap summary::before{content:"▸ ";}
    .fixwrap[open] summary::before{content:"▾ ";}
    .fixcode{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:9px 11px;margin-top:6px;font-family:var(--mono);font-size:.78rem;line-height:1.5;white-space:pre-wrap;word-break:break-word;color:var(--text);overflow-x:auto;}
    /* Fix These First list */
    .prio{display:flex;flex-direction:column;gap:8px;margin:12px 0;}
    .prio-item{display:flex;align-items:center;gap:12px;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:10px 14px;}
    .prio-title{font-weight:600;flex:1;min-width:0;}
    .prio-meta{font-size:.78rem;white-space:nowrap;font-variant-numeric:tabular-nums;}
    /* Grouped findings */
    #findings-list{display:flex;flex-direction:column;gap:8px;margin-top:6px;}
    .fgroup{background:var(--surface);border:1px solid var(--border);border-radius:10px;overflow:hidden;}
    .fgroup>summary{display:flex;align-items:center;gap:12px;padding:11px 14px;cursor:pointer;list-style:none;}
    .fgroup>summary::-webkit-details-marker{display:none;}
    .fgroup>summary::before{content:"▸";color:var(--muted);font-size:.8rem;flex-shrink:0;}
    .fgroup[open]>summary::before{content:"▾";}
    .fgroup>summary:hover{background:var(--surface2);}
    .fgroup-title{font-weight:600;flex:1;min-width:0;}
    .fgroup-cat{font-size:.78rem;white-space:nowrap;}
    .fgroup-count{font-size:.76rem;font-weight:700;color:var(--muted);font-variant-numeric:tabular-nums;background:var(--surface2);border:1px solid var(--border);border-radius:999px;padding:2px 9px;white-space:nowrap;}
    .fgroup-body{padding:4px 16px 14px;border-top:1px solid var(--border);}
    .fgroup-tags{margin:9px 0 4px;}
    .occ{margin-top:10px;}
    .occ-h{color:var(--muted);font-size:.7rem;text-transform:uppercase;letter-spacing:.05em;margin-bottom:5px;}
    .occ-row{display:flex;gap:10px;align-items:baseline;padding:3px 0;flex-wrap:wrap;font-size:.86rem;border-top:1px solid color-mix(in srgb,var(--border) 55%,transparent);}
    .occ-row:first-of-type{border-top:none;}
    .occ-snip{font-size:.76rem;opacity:.85;}
    .banner{border-radius:12px;padding:13px 16px;margin:14px 0;font-weight:600;border:1px solid var(--border);display:flex;align-items:center;gap:8px;}
    .banner.ok{background:color-mix(in srgb,var(--ok) 14%,transparent);color:var(--ok);border-color:color-mix(in srgb,var(--ok) 40%,transparent);}
    .banner.fail{background:color-mix(in srgb,var(--crit) 14%,transparent);color:var(--crit);border-color:color-mix(in srgb,var(--crit) 40%,transparent);}
    .banner.info{background:color-mix(in srgb,var(--accent) 12%,transparent);color:var(--accent);border-color:color-mix(in srgb,var(--accent) 35%,transparent);font-weight:500;}
    .score-A{--c:var(--ok);color:var(--ok);} .score-B{--c:#3f9f6b;color:#3f9f6b;} .score-C{--c:var(--med);color:var(--med);} .score-D{--c:var(--high);color:var(--high);} .score-F{--c:var(--crit);color:var(--crit);}
    .secrating{display:inline-block;min-width:1.4em;text-align:center;border-radius:7px;padding:0 .3em;font-weight:800;}
    .secrating-A{background:color-mix(in srgb,var(--ok) 20%,transparent);color:var(--ok);}
    .secrating-B{background:color-mix(in srgb,#3f9f6b 24%,transparent);color:#3f9f6b;}
    .secrating-C{background:color-mix(in srgb,var(--med) 26%,transparent);color:var(--med);}
    .secrating-D{background:color-mix(in srgb,var(--high) 24%,transparent);color:var(--high);}
    .secrating-E{background:color-mix(in srgb,var(--crit) 24%,transparent);color:var(--crit);}
    .scoring-note{font-size:.8rem;margin-top:12px;line-height:1.5;}
    .tag{display:inline-block;background:var(--surface2);border:1px solid var(--border);color:var(--muted);border-radius:6px;padding:1px 8px;margin-right:5px;font-size:.72rem;text-decoration:none;}
    a.tag:hover{border-color:var(--accent);color:var(--accent);}
    .aicard{margin:12px 0;border-left:3px solid var(--accent);}
    .aihead{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:8px;}
    .aihead .meta{color:var(--muted);font-size:.8rem;}
    .airow{display:flex;gap:12px;padding:3px 0;align-items:baseline;}
    .airow .ailbl{color:var(--muted);font-size:.72rem;text-transform:uppercase;letter-spacing:.04em;min-width:104px;flex-shrink:0;}
    .fixex{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:9px 11px;margin:0;font-family:var(--mono);font-size:.8rem;white-space:pre-wrap;overflow-x:auto;}
    /* instrument-panel hero */
    .hero{position:relative;overflow:hidden;display:grid;grid-template-columns:1fr auto;gap:28px;align-items:center;background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:22px 26px;box-shadow:var(--shadow);}
    /* radar-ripple watermark (echoes the logo) — decorative, theme-aware, zero assets */
    .hero::after{content:"";position:absolute;left:-70px;bottom:-90px;width:280px;height:280px;pointer-events:none;z-index:0;
      background:repeating-radial-gradient(circle, color-mix(in srgb,var(--accent) 26%,transparent) 0 2px, transparent 2px 20px);
      -webkit-mask-image:radial-gradient(circle,#000,transparent 68%);mask-image:radial-gradient(circle,#000,transparent 68%);opacity:.28;}
    .hero>*{position:relative;z-index:1;}
    .stats{display:flex;gap:28px;flex-wrap:wrap;}
    .stat .k{color:var(--muted);font-size:.68rem;text-transform:uppercase;letter-spacing:.05em;}
    .stat .v{font-weight:700;font-size:1.15rem;margin-top:2px;font-variant-numeric:tabular-nums;}
    .sevbar{display:flex;height:10px;border-radius:999px;overflow:hidden;background:var(--surface2);}
    .sevbar .seg{min-width:4px;}
    .sevlegend{display:flex;gap:16px;flex-wrap:wrap;margin-top:9px;font-size:.8rem;color:var(--muted);font-variant-numeric:tabular-nums;}
    .dot{display:inline-block;width:9px;height:9px;border-radius:50%;margin-right:6px;vertical-align:middle;}
    .sev-bg-Critical{background:var(--crit);} .sev-bg-High{background:var(--high);} .sev-bg-Medium{background:var(--med);} .sev-bg-Low{background:var(--low);}
    .gauges{display:flex;gap:18px;}
    .gaugewrap{text-align:center;}
    .gauge{--v:0;--c:var(--accent);width:104px;height:104px;border-radius:50%;background:conic-gradient(var(--c) calc(var(--v)*3.6deg),var(--track) 0);display:grid;place-items:center;margin:0 auto;}
    .gauge-inner{width:80px;height:80px;border-radius:50%;background:var(--surface);display:flex;flex-direction:column;align-items:center;justify-content:center;line-height:1.05;}
    .gauge .num{font-size:1.55rem;font-weight:800;font-variant-numeric:tabular-nums;}
    .gauge .grade{font-size:.78rem;color:var(--muted);font-weight:700;}
    .gaugelbl{margin-top:8px;font-size:.72rem;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;}
    footer{margin-top:46px;padding-top:18px;border-top:1px solid var(--border);color:var(--muted);font-size:.8rem;}
    @media (max-width:820px){.layout{grid-template-columns:1fr;} nav.toc{position:static;height:auto;border-right:none;border-bottom:1px solid var(--border);} .hero{grid-template-columns:1fr;}}
    @media print{
      nav.toc,.controls,.printbtn,.appbar-actions{display:none!important;}
      .layout{grid-template-columns:1fr;max-width:none;}
      body{background:#fff;color:#000;}
      .card,table,.banner,.hero,.aicard,.fgroup,.prio-item{break-inside:avoid;}
      a{color:#000;}
      .fgroup>summary::before{content:"";}
    }
  </style>
  <script>
    (function(){try{var t=localStorage.getItem("observer-theme");if(t)document.documentElement.setAttribute("data-theme",t);}catch(e){}})();
    function toggleTheme(){var d=document.documentElement;var t=d.getAttribute("data-theme")==="light"?"dark":"light";d.setAttribute("data-theme",t);try{localStorage.setItem("observer-theme",t);}catch(e){}}
  </script>
</head>
<body>
<div class="layout">
  <nav class="toc">
    <h4>Contents</h4>
    <a href="#summary">Executive Summary</a>
    <a href="#tech">Technology Stack</a>
    <a href="#priorities">Fix These First <span class="count">{{len .TopPriorities}}</span></a>
    <a href="#findings">All Findings <span class="count">{{.TotalIssues}}</span></a>
    {{if .HasRuntime}}<a href="#runtime">Runtime Errors <span class="count">{{.TotalRuntimeEvents}}</span></a>{{end}}
    {{if .HasLogs}}<a href="#logs">Log Analysis <span class="count">{{.TotalLogErrors}}</span></a>{{end}}
    {{if .HasAI}}<a href="#ai">AI Recommendations</a>{{end}}
    {{if .HasCompliance}}<a href="#compliance">Compliance &amp; Standards</a>{{end}}
    <a href="#structure">Project Structure</a>
  </nav>

  <main>
    <div class="appbar">
      <div class="brand">
        <svg class="logo" width="28" height="28" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2"/>
          <circle cx="12" cy="12" r="6" fill="none" stroke="currentColor" stroke-width="2"/>
          <circle cx="12" cy="12" r="2.6" fill="currentColor"/>
        </svg>
        <span class="brandname">Observer</span>
      </div>
      <div class="appbar-actions">
        <button class="themebtn" onclick="toggleTheme()" title="Toggle light / dark" aria-label="Toggle light or dark theme">◐ Theme</button>
        <button class="printbtn" onclick="window.print()">Print / Save as PDF</button>
      </div>
    </div>
    <header>
      <h1>{{.ProjectName}}</h1>
      <div class="muted">Production Health Report &middot; generated {{.GeneratedAt}}{{if .ScanInfo}} &middot; {{.ScanInfo}}{{end}}</div>
      <div class="muted"><code>{{.RootPath}}</code></div>
    </header>

    {{if .GateEnabled}}
      {{if .GatePassed}}
      <div class="banner ok">✓ Quality gate passed — no findings at or above {{.GateThreshold}} severity.</div>
      {{else}}
      <div class="banner fail">✗ Quality gate FAILED — {{.GateFailCount}} finding(s) at or above {{.GateThreshold}} severity.</div>
      {{end}}
    {{end}}
    {{if .BaselineApplied}}
    <div class="banner info">Baseline active — <strong>{{.BaselineNew}} new</strong> finding(s) since baseline ({{.BaselineSuppressed}} known suppressed).</div>
    {{end}}

    <h2 id="summary">Executive Summary</h2>
    {{if .HasAI}}
    <div class="card" style="margin-bottom:10px">{{.AISummary}}</div>
    <p class="muted">AI provider: <code>{{.AIProvider}}</code> — explanations are grounded in the detected findings.</p>
    {{end}}
    <div class="hero">
      <div class="hero-left">
        <div class="stats">
          <div class="stat"><div class="k">Security rating</div><div class="v"><span class="secrating secrating-{{.SecurityRating}}" title="Standards-aligned: worst security severity present = {{.SecurityRatingBasis}}">{{.SecurityRating}}</span></div></div>
          <div class="stat"><div class="k">Language</div><div class="v">{{.Language}}</div></div>
          <div class="stat"><div class="k">Findings</div><div class="v">{{.TotalIssues}}</div></div>
          <div class="stat"><div class="k">Est. fix effort</div><div class="v">{{.RemediationEffort}}</div></div>
          {{if .HasRuntime}}<div class="stat"><div class="k">Runtime events</div><div class="v">{{.TotalRuntimeEvents}}</div></div>{{end}}
          {{if .HasLogs}}<div class="stat"><div class="k">Log errors</div><div class="v">{{.TotalLogErrors}}</div></div>{{end}}
        </div>
        {{if .IssueSummary}}
        <div style="margin-top:18px">
          <div class="sevbar">{{range .IssueSummary}}<div class="seg sev-bg-{{.Severity}}" style="flex:{{.Count}}" title="{{.Severity}}: {{.Count}}"></div>{{end}}</div>
          <div class="sevlegend">{{range .IssueSummary}}<span><i class="dot sev-bg-{{.Severity}}"></i>{{.Severity}} {{.Count}}</span>{{end}}</div>
        </div>
        {{end}}
      </div>
      <div class="gauges">
        <div class="gaugewrap">
          <div class="gauge score-{{.SecGrade}}" style="--v:{{.SecScore}}"><div class="gauge-inner"><span class="num">{{.SecScore}}</span><span class="grade">{{.SecGrade}}</span></div></div>
          <div class="gaugelbl">Security</div>
        </div>
        <div class="gaugewrap">
          <div class="gauge score-{{.HealthGrade}}" style="--v:{{.HealthScore}}"><div class="gauge-inner"><span class="num">{{.HealthScore}}</span><span class="grade">{{.HealthGrade}}</span></div></div>
          <div class="gaugelbl">Code Health</div>
        </div>
      </div>
    </div>

    <p class="muted scoring-note">
      <strong>How scoring works:</strong> severity, CWE and OWASP tags follow industry standards (CVSS-aligned).
      The <strong>Security rating (A–E)</strong> is standards-style — it reflects the single most severe security
      issue present (E = Critical … A = none), the same model tools like SonarQube use. The <strong>0–100 scores</strong>
      are Observer's own density-based health index (severity-weighted findings per file), so they also reflect volume.
    </p>

    <h2 id="tech">Technology Stack</h2>
    {{template "techtable" dict "Title" "Frameworks" "Items" .Frameworks}}
    {{template "techtable" dict "Title" "Databases" "Items" .Databases}}
    {{template "techtable" dict "Title" "Infrastructure" "Items" .Infrastructure}}

    <h2 id="priorities">Fix These First</h2>
    {{if .TopPriorities}}
    <p class="muted">The highest-severity issues, grouped and ranked. Start here — the full list of locations and the fix for each is in All Findings, just below.</p>
    <div class="prio">
      {{range .TopPriorities}}
      <div class="prio-item">
        <span class="sevbadge sev-{{.Severity}}">{{.Severity}}</span>
        <span class="prio-title">{{.Title}}</span>
        <span class="prio-meta muted">{{.Category}} · {{.Count}}×</span>
      </div>
      {{end}}
    </div>
    <a class="pill" data-quick="criticalhigh|all" href="#findings">Show all Critical &amp; High ↓</a>
    {{else}}
    <p class="empty">No Critical or High severity issues detected — a good sign.</p>
    {{end}}

    <h2 id="findings">All Findings</h2>
    <p class="muted">
      {{.TotalIssues}} occurrence(s) across {{.FilesScanned}} scanned file(s), grouped into {{len .IssueGroups}} issue type(s), highest severity first.
      Expand a row to see every location (clickable — opens in VS Code) and the suggested fix. Findings are heuristic — confirm before acting.
    </p>
    {{if .IssueGroups}}
    <div class="controls">
      <button data-sevfilter="all" class="active">All</button>
      <button data-sevfilter="Critical">Critical</button>
      <button data-sevfilter="High">High</button>
      <button data-sevfilter="Medium">Medium</button>
      <button data-sevfilter="Low">Low</button>
      <select id="catFilter">
        <option value="all">All categories</option>
        {{range .FindingCategories}}<option value="{{.}}">{{.}}</option>{{end}}
      </select>
      <input id="searchBox" type="search" placeholder="Search findings…">
      <span class="muted" id="matchCount"></span>
    </div>
    <div id="findings-list">
      {{range .IssueGroups}}
      <details class="fgroup" data-sev="{{.Severity}}" data-cat="{{.Category}}">
        <summary>
          <span class="sevbadge sev-{{.Severity}}">{{.Severity}}</span>
          <span class="fgroup-title">{{.Title}}</span>
          <span class="fgroup-cat muted">{{.Category}}</span>
          <span class="fgroup-count">{{.Count}}×</span>
        </summary>
        <div class="fgroup-body">
          <div class="fgroup-tags">
            {{if .CWE}}<a class="tag" href="{{.CWELink}}" target="_blank" rel="noopener">{{.CWE}}</a>{{end}}
            {{if .OWASP}}<a class="tag" href="{{.OWASPLink}}" target="_blank" rel="noopener">OWASP {{.OWASP}}</a>{{end}}
            <span class="muted" style="font-size:.72rem">CVSS ~{{.CVSS}}</span>
          </div>
          {{if .Explanation}}<div class="muted" style="margin:4px 0">{{.Explanation}}</div>{{end}}
          <div class="fix"><em>Fix:</em> {{.Recommendation}}</div>
          {{if .FixExample}}<details class="fixwrap"><summary>Suggested fix</summary><pre class="fixcode">{{.FixExample}}</pre></details>{{end}}
          <div class="occ">
            <div class="occ-h">Where — {{.Count}} occurrence(s)</div>
            {{range .Occurrences}}
            <div class="occ-row">
              {{if .HasLink}}<a href="{{.Link}}" title="Open in VS Code">{{.Location}}</a>{{else}}<code>{{.Location}}</code>{{end}}
              {{if .Snippet}}<code class="occ-snip">{{.Snippet}}</code>{{end}}
            </div>
            {{end}}
            {{if .ExtraCount}}<div class="muted" style="font-size:.8rem;margin-top:4px">… and {{.ExtraCount}} more occurrence(s)</div>{{end}}
          </div>
        </div>
      </details>
      {{end}}
    </div>
    {{else}}
    <p class="empty">No issues detected by the current rule set.</p>
    {{end}}

    {{if .HasRuntime}}
    <h2 id="runtime">Runtime Errors</h2>
    <p class="muted">{{.TotalRuntimeEvents}} captured event(s), grouped by signature (most frequent first).</p>
    {{if .RuntimeGroups}}
    <table>
      <thead><tr><th>Occurrences</th><th>Type</th><th>Location</th><th>Last seen</th><th>Message</th></tr></thead>
      <tbody>
        {{range .RuntimeGroups}}<tr>
          <td><strong>{{.Count}}</strong></td>
          <td>{{.Type}}</td>
          <td>{{if .HasLink}}<a href="{{.Link}}" title="Open in VS Code">{{.Location}}</a>{{else}}<code>{{.Location}}</code>{{end}}</td>
          <td class="muted">{{.LastSeen}}</td>
          <td class="muted">{{.Message}}</td>
        </tr>{{end}}
      </tbody>
    </table>
    {{else}}<p class="empty">No runtime events captured.</p>{{end}}
    {{end}}

    {{if .HasLogs}}
    <h2 id="logs">Log Analysis</h2>
    <p class="muted">{{.TotalLogErrors}} error-level entr(ies) across {{.LogFilesParsed}} log file(s), grouped by signature.</p>
    {{if .LogGroups}}
    <table>
      <thead><tr><th>Occurrences</th><th>Level</th><th>Category</th><th>Most recent message</th><th>Last seen</th></tr></thead>
      <tbody>
        {{range .LogGroups}}<tr>
          <td><strong>{{.Count}}</strong></td>
          <td><span class="sevbadge">{{.Level}}</span></td>
          <td class="muted">{{.Category}}</td>
          <td>{{.Sample}}{{if .Cause}}<div class="fix"><em>Possible cause:</em> {{.Cause}}</div>{{end}}</td>
          <td class="muted">{{.LastSeen}}</td>
        </tr>{{end}}
      </tbody>
    </table>
    {{else}}<p class="empty">No error-level log entries found.</p>{{end}}
    {{end}}

    {{if .HasAI}}
    <h2 id="ai">AI Recommendations</h2>
    {{if .AIInsights}}
    {{range .AIInsights}}
    <div class="card aicard">
      <div class="aihead">
        <span class="sevbadge sev-{{.Severity}}">{{.Severity}}</span>
        <strong>{{.Title}}</strong>
        {{if .Complexity}}<span class="meta">Fix complexity: <b>{{.Complexity}}</b></span>{{end}}
        {{if .Effort}}<span class="meta">Effort: <b>{{.Effort}}</b></span>{{end}}
      </div>
      {{if .Problem}}<div class="airow"><span class="ailbl">Problem</span><span>{{.Problem}}</span></div>{{end}}
      {{if .RootCause}}<div class="airow"><span class="ailbl">Root cause</span><span class="muted">{{.RootCause}}</span></div>{{end}}
      {{if .Impact}}<div class="airow"><span class="ailbl">Impact</span><span class="muted">{{.Impact}}</span></div>{{end}}
      {{if .Exploit}}<div class="airow"><span class="ailbl">Exploitability</span><span class="muted">{{.Exploit}}</span></div>{{end}}
      {{if .Suggestion}}<div class="airow"><span class="ailbl">Fix</span><span>{{.Suggestion}}</span></div>{{end}}
      {{if .FixExample}}<div class="airow"><span class="ailbl">Example</span><pre class="fixex">{{.FixExample}}</pre></div>{{end}}
    </div>
    {{end}}
    {{else}}<p class="empty">No AI insights generated.</p>{{end}}

    <h2 id="priority">Suggested Fix Priority</h2>
    {{if .AIPriorities}}
    <ol>{{range .AIPriorities}}<li>{{.}}</li>{{end}}</ol>
    {{else}}<p class="empty">No prioritization available.</p>{{end}}
    {{end}}

    {{if .HasCompliance}}
    <h2 id="compliance">Compliance &amp; Standards</h2>
    <p class="muted">Indicative mapping to support audits — not a certification. Findings are mapped from their CWE/OWASP tags.</p>

    <h3 class="sub">OWASP Top 10 (2021) coverage</h3>
    <table>
      <thead><tr><th>Category</th><th>Findings</th><th>Status</th></tr></thead>
      <tbody>
        {{range .OWASPRows}}<tr>
          <td><strong>{{.Code}}</strong> {{.Name}}</td>
          <td>{{.Count}}</td>
          <td>{{if eq .Status "Issues found"}}<span class="sevbadge sev-High">{{.Status}}</span>{{else if eq .Status "No issues detected"}}<span class="conf conf-High">{{.Status}}</span>{{else}}<span class="muted">{{.Status}}</span>{{end}}</td>
        </tr>{{end}}
      </tbody>
    </table>

    <h3 class="sub">PCI-DSS &amp; ISO/IEC 27001 mapping</h3>
    <table>
      <thead><tr><th>Area</th><th>OWASP</th><th>PCI-DSS</th><th>ISO 27001</th><th>Status</th></tr></thead>
      <tbody>
        {{range .FrameworkRows}}<tr>
          <td>{{.Area}}</td>
          <td class="muted">{{.OWASP}}</td>
          <td class="muted">{{.PCIDSS}}</td>
          <td class="muted">{{.ISO}}</td>
          <td>{{if eq .Status "Action needed"}}<span class="sevbadge sev-Medium">{{.Status}} ({{.Count}})</span>{{else}}<span class="conf conf-High">OK</span>{{end}}</td>
        </tr>{{end}}
      </tbody>
    </table>

    {{if .CWERows}}
    <h3 class="sub">CWE breakdown</h3>
    <table>
      <thead><tr><th>CWE</th><th>Findings</th></tr></thead>
      <tbody>
        {{range .CWERows}}<tr><td><code>{{.ID}}</code></td><td>{{.Count}}</td></tr>{{end}}
      </tbody>
    </table>
    {{end}}
    {{end}}

    <h2 id="structure">Project Structure</h2>
    {{if .Categories}}
    <table>
      <thead><tr><th>Category</th><th>Count</th></tr></thead>
      <tbody>{{range .Categories}}<tr><td>{{.Key}}</td><td>{{.Value}}</td></tr>{{end}}</tbody>
    </table>
    {{else}}<p class="empty">No recognizable architectural categories found.</p>{{end}}

    <footer>
      Generated by <strong>Observer</strong> — AI Production Debugging Assistant.
      Findings are heuristic; confirm before acting. Location links use the <code>vscode://</code> scheme and require VS Code.
    </footer>
  </main>
</div>

<script>
(function () {
  var rows = Array.prototype.slice.call(document.querySelectorAll('#findings-list .fgroup'));
  if (!rows.length) return;
  var state = { sev: 'all', cat: 'all', q: '' };
  var matchEl = document.getElementById('matchCount');

  // Label each filter with how many issue types it covers, e.g. "High (2)".
  (function labelCounts() {
    var sev = { all: rows.length, Critical: 0, High: 0, Medium: 0, Low: 0 }, cat = {};
    rows.forEach(function (r) {
      var s = r.getAttribute('data-sev'); if (sev[s] != null) sev[s]++;
      var c = r.getAttribute('data-cat'); cat[c] = (cat[c] || 0) + 1;
    });
    document.querySelectorAll('[data-sevfilter]').forEach(function (b) {
      var k = b.getAttribute('data-sevfilter');
      if (sev[k] != null) b.textContent = b.textContent.replace(/\s*\(\d+\)$/, '') + ' (' + sev[k] + ')';
    });
    var cs = document.getElementById('catFilter');
    if (cs) Array.prototype.forEach.call(cs.options, function (o) {
      var n = o.value === 'all' ? rows.length : (cat[o.value] || 0);
      o.textContent = o.textContent.replace(/\s*\(\d+\)$/, '') + ' (' + n + ')';
    });
  })();

  function matches(r) {
    var okSev = state.sev === 'all'
      || r.getAttribute('data-sev') === state.sev
      || (state.sev === 'criticalhigh' && (r.getAttribute('data-sev') === 'Critical' || r.getAttribute('data-sev') === 'High'));
    var okCat = state.cat === 'all' || r.getAttribute('data-cat') === state.cat;
    var okQ = state.q === '' || r.textContent.toLowerCase().indexOf(state.q) !== -1;
    return okSev && okCat && okQ;
  }
  function apply() {
    var shown = 0;
    rows.forEach(function (r) {
      var ok = matches(r);
      r.style.display = ok ? '' : 'none';
      if (ok) shown++;
    });
    if (matchEl) matchEl.textContent = shown + ' of ' + rows.length + ' issue type(s) shown';
  }
  function setActiveSev(val) {
    document.querySelectorAll('[data-sevfilter]').forEach(function (b) {
      b.classList.toggle('active', b.getAttribute('data-sevfilter') === val);
    });
  }

  document.querySelectorAll('[data-sevfilter]').forEach(function (b) {
    b.addEventListener('click', function () { state.sev = b.getAttribute('data-sevfilter'); setActiveSev(state.sev); apply(); });
  });
  var catSel = document.getElementById('catFilter');
  if (catSel) catSel.addEventListener('change', function () { state.cat = catSel.value; apply(); });
  var search = document.getElementById('searchBox');
  if (search) search.addEventListener('input', function () { state.q = search.value.toLowerCase(); apply(); });

  document.querySelectorAll('[data-quick]').forEach(function (a) {
    a.addEventListener('click', function () {
      var parts = a.getAttribute('data-quick').split('|');
      state.sev = parts[0] || 'all';
      state.cat = parts[1] || 'all';
      if (catSel) catSel.value = state.cat;
      setActiveSev(state.sev === 'criticalhigh' ? 'all' : state.sev);
      apply();
    });
  });

  apply();

  // Expand all visible groups when printing / saving to PDF, then restore.
  window.addEventListener('beforeprint', function () {
    rows.forEach(function (d) { d.dataset._open = d.open ? '1' : ''; d.open = true; });
  });
  window.addEventListener('afterprint', function () {
    rows.forEach(function (d) { d.open = d.dataset._open === '1'; });
  });
})();
</script>
</body>
</html>
